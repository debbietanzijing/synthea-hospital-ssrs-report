  <DataSources>
    <DataSource Name="SyntheaHospital">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=SyntheaHospital;TrustServerCertificate=True</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>6dbb2952-5187-42b7-8fe7-d7e706354177</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="EncounterDetail">
      <Query>
        <DataSourceName>SyntheaHospital</DataSourceName>
        <CommandText>SELECT p.FIRST, p.LAST, p.GENDER, DATEDIFF(year, p.BIRTHDATE, GETDATE()) AS AGE, e.START AS AdmissionDate, e.STOP AS DischargeDate, DATEDIFF(day, e.START, e.STOP) AS LengthOfStay, e.ENCOUNTERCLASS AS Department, e.REASONDESCRIPTION AS ReasonForVisit, c.DESCRIPTION AS Diagnosis
FROM  patients AS p INNER JOIN
         encounters AS e ON p.Id = e.PATIENT LEFT OUTER JOIN
         conditions AS c ON p.Id = c.PATIENT AND e.Id = c.ENCOUNTER</CommandText>
      </Query>
      <Fields>
        <Field Name="FIRST">
          <DataField>FIRST</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LAST">
          <DataField>LAST</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GENDER">
          <DataField>GENDER</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AGE">
          <DataField>AGE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AdmissionDate">
          <DataField>AdmissionDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DischargeDate">
          <DataField>DischargeDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LengthOfStay">
          <DataField>LengthOfStay</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Department">
          <DataField>Department</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReasonForVisit">
          <DataField>ReasonForVisit</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Diagnosis">
          <DataField>Diagnosis</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
